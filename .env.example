# ── Cardio AI Sales Engine — Environment Variables ──────────────────────
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── Anthropic AI ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Google OAuth (Gmail API) ─────────────────────────────────────────────
# Get from: https://console.cloud.google.com
# Enable: Gmail API
# Create: OAuth 2.0 Web Application credentials
GOOGLE_CLIENT_ID=your_google_client_id_825165837873-guubgeden7d2m7g9ghlti60le1d054o7.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_GOCSPX-Il3yWHij4MzlxhIgiW8FsjkJm6HQ
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/callback
# Production: GOOGLE_REDIRECT_URI=https://sales.cardioailive.com/auth/callback

# ── Apollo.io ────────────────────────────────────────────────────────────
# Get from: https://app.apollo.io/settings/api
APOLLO_API_KEY=your_apollo_api_key_here

# ── Server ───────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── CORS ─────────────────────────────────────────────────────────────────
# Set to your frontend domain in production
ALLOWED_ORIGIN=https://sales.cardioailive.com
# Development: ALLOWED_ORIGIN=http://localhost:3000

# ── Cardio AI ────────────────────────────────────────────────────────────
SENDER_EMAIL=tonywell@cardioailive.com
SENDER_NAME=Sampson Kontomah


# ── Database (PostgreSQL) ─────────────────────────────────────────────────
# Render PostgreSQL: copy the "Internal Database URL" from your Render DB dashboard
# Format: postgresql://user:password@host:5432/dbname
# Leave blank to use file storage (/tmp/cardioai_data.json)
DATABASE_URL=postgresql://user:password@host:5432/cardioai_db

# ── Authentication ────────────────────────────────────────────────────────
# Random secret for session encryption — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=generate_a_random_64_char_hex_string_here

# Only users with this email domain can sign in
ALLOWED_EMAIL_DOMAIN=cardioailive.com

# Additional allowed emails outside the domain (comma-separated, optional)
# ALLOWED_EMAILS=partner@otherdomain.com,advisor@gmail.com
